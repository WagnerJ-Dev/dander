# Copy to .env and fill in. .env is git-ignored — NEVER commit real values.
# In production, these are resolved from GCP Secret Manager, not .env. See steering/01-security.md.

# ── GCP core ──────────────────────────────────────────────────────────
GCP_PROJECT_ID=
GCP_REGION=us-central1
# Local dev only. In cloud, use Workload Identity Federation (no key file).
GOOGLE_APPLICATION_CREDENTIALS=

# ── BigQuery target ───────────────────────────────────────────────────
BQ_DATASET_RAW=raw
BQ_DATASET_STAGING=staging
BQ_DATASET_MARTS=marts

# ── Secret Manager references (resource names, NOT the secret values) ──
# e.g. projects/my-proj/secrets/salesforce-prod/versions/latest
SECRET_SALESFORCE=
SECRET_GREENHOUSE=
SECRET_MARKETO=
